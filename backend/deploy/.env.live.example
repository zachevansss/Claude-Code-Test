# ------------------------------------------------------------------
# LIVE-MODE .env TEMPLATE
# ------------------------------------------------------------------
# Copy this to backend/.env on the VPS and fill in the placeholder
# values. Then start the bot.
#
# DO NOT commit a real .env. Real .env is gitignored.
# DO back up MASTER_ENCRYPTION_KEY to a password manager before
# going live — losing it permanently locks all stored wallets.
# ------------------------------------------------------------------

# Mode: "paper" or "live". Start in paper for first 24h on the VPS,
# then flip to live AFTER funding the wallet and applying settings.
MODE=paper

# JWT auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=PASTE_LONG_RANDOM_STRING_HERE
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=240

# Database — SQLite is fine for single-user. Upgrade to Postgres later.
DATABASE_URL=sqlite:///./copytrade.db

# Bot loop — 5s is the default. Don't go below 3s (Polymarket rate limits).
BOT_POLL_INTERVAL_SECONDS=5

# Polymarket
POLYMARKET_BASE_URL=https://clob.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYGON_CHAIN_ID=137

# REQUIRED for live: paid Polygon RPC. Public default rate-limits with 401s.
# Get one free from Alchemy / Infura / QuickNode.
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/PASTE_YOUR_API_KEY

# REQUIRED for live: Fernet encryption key for managed-wallet private keys.
# Generate with:  cd backend && ./.venv/bin/python -m src.wallet.crypto generate
# BACK THIS UP. Losing it = permanently losing access to all stored wallets.
MASTER_ENCRYPTION_KEY=PASTE_FERNET_KEY_HERE

# Live trading kill switch.
# KEEP THIS FALSE until you have funded the wallet, applied settings,
# and are ready to flip live. Even with MODE=live, the executor refuses
# to place orders unless this is True.
LIVE_TRADING_ENABLED=False

# Execution tuning (defaults are fine)
EXECUTION_MAX_RETRIES=3
EXECUTION_RETRY_BACKOFF_SECONDS=1.0

# Logging
LOG_LEVEL=INFO
