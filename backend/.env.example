# Mode: "paper" or "live". Live execution is intentionally not implemented yet
# (see backend/src/executor/engine.py).
MODE=paper

# Auth — JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Database — SQLite for dev, swap to PostgreSQL for prod
DATABASE_URL=sqlite:///./copytrade.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/copytrade

# Bot loop
BOT_POLL_INTERVAL_SECONDS=5

# Polymarket / chain
POLYMARKET_BASE_URL=https://clob.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYGON_CHAIN_ID=137
POLYGON_RPC_URL=https://polygon-rpc.com

# Wallet encryption — REQUIRED before signup works.
# Generate with:  .venv/Scripts/python -m src.wallet.crypto generate
MASTER_ENCRYPTION_KEY=

# Live-trading kill switch. Leave False until you have explicitly tested
# end-to-end and accepted the risk. Even setting MODE=live and a user
# choosing live mode won't place orders unless this is True.
LIVE_TRADING_ENABLED=False

# Execution tuning
EXECUTION_MAX_RETRIES=3
EXECUTION_RETRY_BACKOFF_SECONDS=1.0

# Logging
LOG_LEVEL=INFO
